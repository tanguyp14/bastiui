    },
    {
      "type": "color",
      "id": "button_border_color",
      "label": "Bordure bouton",
      "default": "#e6e6e6"
    },
    {
      "type": "range",
      "id": "button_border_width",
      "label": "Épaisseur bordure",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Arrondi bouton",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
