      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arrondi des coins",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 8
    },
    {
      "type": "header",
      "content": "Contrôles"
    },
    {
      "type": "checkbox",
      "id": "show_controls",
      "label": "Afficher les boutons",
      "default": true
    },
    {
      "type": "range",
      "id": "controls_spacing",
      "label": "Espacement des boutons",
      "min": 0,
      "max": 40,
      "step": 4,
